generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CampaignStatus {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
}

enum DeliverableType {
  BANNER
  VIDEO
  COPY
}

enum DeliverableStatus {
  PENDING
  REVIEW
  APPROVED
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

enum BillingType {
  MILESTONE
  MONTHLY
}


model Client {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  phone     String?
  address   String?
  campaigns Campaign[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Campaign {
  id           String         @id @default(cuid())
  name         String
  budget       Float
  adsType      String
  startDate    DateTime
  endDate      DateTime
  estimatedRoi Float?
  status       CampaignStatus @default(PLANNING)
  color        String?        @default("#3b82f6")
  targetAudience Int?
  expectedReach  Int?
  clientId     String
  client       Client         @relation(fields: [clientId], references: [id])
  deliverables Deliverable[]
  teams        Team[]         @relation("TeamCampaigns")
  invoices     Invoice[]
  moodboards   Moodboard[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Deliverable {
  id         String            @id @default(cuid())
  title      String
  description String?
  type       DeliverableType
  status     DeliverableStatus @default(PENDING)
  startDate  DateTime?
  endDate    DateTime?
  campaignId String
  campaign   Campaign          @relation(fields: [campaignId], references: [id])
  teams      Team[]            @relation("TeamDeliverables")
  invoices   Invoice[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

enum SystemRole {
  ADMIN
  CREATIVE
}

model TeamMember {
  id         String     @id @default(cuid())
  name       String
  email      String     @unique
  password   String     // Initial password for access
  role       String     // Creative role (Designer, etc.)
  systemRole SystemRole @default(CREATIVE)
  teams      Team[]     @relation("TeamMembership")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Team {
  id          String       @id @default(cuid())
  name        String
  description String?
  members     TeamMember[] @relation("TeamMembership")
  campaigns   Campaign[]   @relation("TeamCampaigns")
  deliverables Deliverable[] @relation("TeamDeliverables")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Invoice {
  id            String        @id @default(cuid())
  amount        Float
  dueDate       DateTime
  description   String?
  type          BillingType   @default(MILESTONE)
  status        InvoiceStatus @default(PENDING)
  campaignId    String
  campaign      Campaign      @relation(fields: [campaignId], references: [id])
  deliverableId String?
  deliverable   Deliverable?  @relation(fields: [deliverableId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Moodboard {
  id         String   @id @default(cuid())
  title      String
  urls       String[] // Array of reference links
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
